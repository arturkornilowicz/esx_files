      <xs:sequence>
	<xs:element ref="Variable"/>
	<xs:element ref="ReservedDscr-Type"/>
      </xs:sequence>
      <xs:attribute ref="position"/>
    </xs:complexType>
  </xs:element>
    
  <xs:element name="ImplicitExemplification">
    <xs:complexType>
      <xs:group ref="Term"/>
    </xs:complexType>
  </xs:element>

  <xs:group name="JustifiedProposition">
    <xs:sequence>
      <xs:element ref="Proposition"/>
      <xs:group ref="Justification"/>
    </xs:sequence>
  </xs:group>
  
