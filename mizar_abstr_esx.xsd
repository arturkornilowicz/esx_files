  <xs:element name="Ancestors">
    <xs:complexType>
      <xs:sequence minOccurs="0" maxOccurs="unbounded">
	<xs:element ref="Struct-Type"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>

  <xs:element name="Field-Segments">
    <xs:complexType>
      <xs:sequence minOccurs="1" maxOccurs="unbounded">
	<xs:element ref="Field-Segment"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>

  <xs:element name="Field-Segment">
    <xs:complexType>
      <xs:sequence minOccurs="1" maxOccurs="unbounded">
	<xs:element ref="Selectors"/>
	<xs:group ref="Type"/>
      </xs:sequence>
      <xs:attribute ref="position" use="required"/>
