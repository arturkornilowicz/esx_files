    <xs:complexType>
      <xs:attribute ref="idnr" use="required"/>
      <xs:attribute ref="spelling" use="required"/>
      <xs:attribute ref="position" use="required"/>
      <xs:attribute ref="serialnr" use="required"/>
      <xs:attribute ref="labelnr" use="required"/>
    </xs:complexType>
  </xs:element>

  <xs:element name="Loci">
    <xs:complexType>
      <xs:sequence>
	<xs:element ref="Locus" minOccurs="0" maxOccurs="unbounded"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>

  <xs:element name="Loci-Equalities">
    <xs:complexType>
      <xs:sequence>
	<xs:element ref="Loci-Equality" minOccurs="0" maxOccurs="unbounded"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  
  <xs:element name="Loci-Equality">
    <xs:complexType>
      <xs:sequence>
	<xs:element ref="Locus" minOccurs="2" maxOccurs="2"/>
      </xs:sequence>
      <xs:attribute ref="position" use="required"/>
    </xs:complexType>
  </xs:element>
  
  <xs:element name="Locus">
    <xs:complexType>
      <xs:attribute ref="idnr" use="required"/>
      <xs:attribute ref="varidkind" use="required"/>
