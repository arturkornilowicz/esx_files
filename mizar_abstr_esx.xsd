  </xs:element>

  <xs:group name="Segment">
    <xs:choice>
      <xs:element ref="Implicitly-Qualified-Segment"/>
      <xs:element ref="Explicitly-Qualified-Segment"/>
      <xs:element ref="Free-Variable-Segment"/>
    </xs:choice>
  </xs:group>
  
  <xs:group name="Statements">
    <xs:choice>
      <xs:group ref="DiffuseStatementExtra"/>
      <xs:group ref="JustifiedProposition"/>
