  <xs:element name="Substitutions">
    <xs:complexType>
      <xs:sequence>
	<xs:element ref="Substitution" minOccurs="0" maxOccurs="unbounded"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  
  <xs:element name="Type-Specification">
    <xs:complexType>
      <xs:sequence>
	<xs:group ref="Type"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  
  <xs:element name="Canceled">
