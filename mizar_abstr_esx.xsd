  <xs:element name="Diffuse-Statement">
    <xs:complexType>
      <xs:sequence>
	<xs:element ref="Label"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>

  <xs:element name="Equalities-List">
    <xs:complexType>
      <xs:sequence>
	<xs:group ref="Equalities"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>

  <xs:group name="Equalities">
    <xs:choice>
      <xs:element ref="Equality-To-Itself"/>
    </xs:choice>
  </xs:group>

  <xs:element name="Equality-To-Itself">
    <xs:complexType>
      <xs:sequence>
	<xs:element ref="Variable"/>
	<xs:group ref="Term"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>

  <xs:element name="Equating">
    <xs:complexType>
      <xs:sequence>
	<xs:element ref="Variable"/>
	<xs:group ref="Term"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  
  <xs:group name="Exemplifications">
    <xs:choice>
      <xs:element ref="ImplicitExemplification"/>
    </xs:choice>
  </xs:group>

  <xs:element name="Explicitly-Qualified-Segment">
    <xs:complexType>
      <xs:sequence>
	<xs:element ref="Variables"/>
	<xs:group ref="Type"/>
      </xs:sequence>
      <xs:attribute ref="position"/>
    </xs:complexType>
  </xs:element>
    
  <xs:element name="Free-Variable-Segment">
    <xs:complexType>
      <xs:sequence>
	<xs:element ref="Variable"/>
