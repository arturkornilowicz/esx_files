      <xs:attribute ref="spelling"/>
      <xs:attribute ref="position"/>
      <xs:attribute ref="origin"/>
      <xs:attribute ref="kind"/>
      <xs:attribute ref="serialnr"/>
      <xs:attribute ref="varnr"/>
    </xs:complexType>
  </xs:element>
  
  <xs:element name="Implicitly-Qualified-Segment">
