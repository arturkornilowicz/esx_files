  </xs:element>

  <xs:element name="Selector">
    <xs:complexType>
      <xs:sequence minOccurs="1" maxOccurs="unbounded">
	<xs:element ref="Locus"/>
      </xs:sequence>
      <xs:attribute ref="nr" use="required"/>
      <xs:attribute ref="spelling" use="required"/>
      <xs:attribute ref="position" use="required"/>
    </xs:complexType>
  </xs:element>

  <xs:element name="Selectors-List">
    <xs:complexType>
      <xs:sequence minOccurs="1" maxOccurs="unbounded">
	<xs:element ref="SelectorFunctor-Pattern"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>

  <xs:element name="Strict-Pattern">
    <xs:complexType>
      <xs:sequence>
	<xs:element ref="Locus" minOccurs="1" maxOccurs="1"/>
