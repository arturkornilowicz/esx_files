      <xs:attribute ref="position" use="required"/>
      <xs:attribute ref="origin" use="required"/>
      <xs:attribute ref="kind" use="required"/>
      <xs:attribute ref="serialnr" use="required"/>
      <xs:attribute ref="varnr" use="required"/>
    </xs:complexType>
  </xs:element>

  <xs:element name="Proposition">
    <xs:complexType>
      <xs:sequence>
	<xs:element ref="Label" minOccurs="1" maxOccurs="1"/>
	<xs:group ref="Formula" minOccurs="1" maxOccurs="1"/>
      </xs:sequence>
      <xs:attribute ref="position" use="required"/>
    </xs:complexType>
  </xs:element>
  
  <xs:element name="Qualified-Segments">
    <xs:complexType>
      <xs:sequence minOccurs="0" maxOccurs="unbounded">
	<xs:group ref="Segment"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>

  <xs:element name="Properties">
    <xs:complexType>
      <xs:sequence>
	<xs:group ref="Type" minOccurs="0" maxOccurs="1"/>
      </xs:sequence>
      <xs:attribute ref="property"/>
    </xs:complexType>
  </xs:element>

  <xs:element name="Redefine">
    <xs:complexType>
      <xs:attribute ref="occurs"/>
    </xs:complexType>
  </xs:element>

  <xs:element name="Reservation-Segment">
    <xs:complexType>
      <xs:sequence>
	<xs:element ref="Variables"/>
	<xs:element ref="Variable-Segments"/>
	<xs:group ref="Type"/>
      </xs:sequence>
      <xs:attribute ref="position"/>
    </xs:complexType>
  </xs:element>

  <xs:element name="Restriction">
    <xs:complexType>
      <xs:sequence minOccurs="0">
	<xs:group ref="Formula"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
    
  <xs:element name="Right-Circumflex-Symbol">
    <xs:complexType>
      <xs:attribute ref="nr"/>
      <xs:attribute ref="formatnr"/>
      <xs:attribute ref="spelling"/>
      <xs:attribute ref="position"/>
    </xs:complexType>
  </xs:element>
    
  <xs:element name="Scope">
