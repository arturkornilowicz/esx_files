      <xs:attribute ref="formatnr" use="required"/>
      <xs:attribute ref="spelling" use="required"/>
      <xs:attribute ref="position" use="required"/>
      <xs:attribute ref="patternnr" use="required"/>
      <xs:attribute ref="absolutepatternMMLId" use="required"/>
      <xs:attribute ref="constr" use="required"/>
      <xs:attribute ref="absoluteconstrMMLId" use="required"/>
    </xs:complexType>
  </xs:element>

  <xs:element name="SelectorFunctor-Pattern">
    <xs:complexType>
      <xs:sequence>
	<xs:element ref="Loci" minOccurs="1" maxOccurs="1"/>
      </xs:sequence>
      <xs:attribute ref="formatdes" use="required"/>
      <xs:attribute ref="formatnr" use="required"/>
      <xs:attribute ref="spelling" use="required"/>
      <xs:attribute ref="position" use="required"/>
      <xs:attribute ref="patternnr" use="required"/>
      <xs:attribute ref="absolutepatternMMLId" use="required"/>
      <xs:attribute ref="constr" use="required"/>
      <xs:attribute ref="absoluteconstrMMLId" use="required"/>
